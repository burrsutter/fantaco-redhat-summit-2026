# FantaCo Environment Variables
# Copy to .env and fill in actual values

# OpenAI — used by fantaco-product-main/tools/generate_images.py
OPENAI_API_KEY=CHANGE_ME

# LLM (OpenAI-compatible) — used by sales-policy-search and hr-policy-search RAG services
LLM_API_KEY=CHANGE_ME
LLM_API_BASE_URL=https://litellm-prod.apps.maas.redhatworkshops.io
LLM_MODEL_NAME=qwen3-14b

# Anthropic — optional, used by OpenClaw gateway
ANTHROPIC_API_KEY=CHANGE_ME

# Telegram — used by OpenClaw gateway
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Telegram user ID — restricts bot access to your account only
# Find yours by messaging @userinfobot on Telegram
TELEGRAM_USER_ID=CHANGE_ME

# OpenShift cluster
OPENSHIFT_CONSOLE_URL=https://console-openshift-console.apps.YOUR_CLUSTER.opentlc.com/

# Student Password
STUDENT_PASSWORD=CHANGE_ME
STUDENT_OPENSHIFT_PASSWORD=CHANGE_ME

# Admin User & Password
ADMIN_USER=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# OpenClaw model server API key
MODEL_API_KEY=CHANGE_ME
